{
  "name": "Dashtab",
  "description": "A personal new tab dashboard",
  "version": "1.0",
  "manifest_version": 3,
  "icons": {
    "16": "icon-16.png",
    "32": "icon-32.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  },
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "permissions": ["storage", "identity", "geolocation"],
  "host_permissions": ["https://api.open-meteo.com/*"]
}
